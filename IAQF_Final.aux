\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces SVB window (March 10--13): unadjusted dispersion $D_t$ vs.\ adjusted residual $B_t$ on Kraken. The USDC de-peg dominates $D_t$, while $B_t$ remains far smaller after marking the stablecoin leg to USD.}}{3}{figure.1}\protected@file@percent }
\newlabel{fig:disp_vs_adj}{{1}{3}{SVB window (March 10--13): unadjusted dispersion $D_t$ vs.\ adjusted residual $B_t$ on Kraken. The USDC de-peg dominates $D_t$, while $B_t$ remains far smaller after marking the stablecoin leg to USD}{figure.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Panel A: intra-exchange adjusted parity residuals ($B_t$) on Kraken and Coinbase. Panel B: USDC/USDT relative adjusted residual on Binance.}}{4}{figure.2}\protected@file@percent }
\newlabel{fig:basis_ts}{{2}{4}{Panel A: intra-exchange adjusted parity residuals ($B_t$) on Kraken and Coinbase. Panel B: USDC/USDT relative adjusted residual on Binance}{figure.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Panel A: stablecoin spot prices vs.\ USD. Panel B: peg deviations from \$1.00 (bps). USDC falls sharply while USDT trades at a premium, consistent with a flight-to-quality rotation within the stablecoin market.}}{4}{figure.3}\protected@file@percent }
\newlabel{fig:peg}{{3}{4}{Panel A: stablecoin spot prices vs.\ USD. Panel B: peg deviations from \$1.00 (bps). USDC falls sharply while USDT trades at a premium, consistent with a flight-to-quality rotation within the stablecoin market}{figure.3}{}}
