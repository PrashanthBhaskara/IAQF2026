\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Cross-exchange basis: BTC/USDT (Binance vs.\ Kraken, Coinbase vs.\ Kraken) and BTC/USD (Coinbase vs.\ Kraken). The fiat channel (Panel C) shows a persistent positive basis that remains elevated post-crisis.}}{5}{figure.4}\protected@file@percent }
\newlabel{fig:xbasis}{{4}{5}{Cross-exchange basis: BTC/USDT (Binance vs.\ Kraken, Coinbase vs.\ Kraken) and BTC/USD (Coinbase vs.\ Kraken). The fiat channel (Panel C) shows a persistent positive basis that remains elevated post-crisis}{figure.4}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.3}Liquidity, volatility, and volume dynamics}{5}{subsection.3.3}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Roll (1984) effective spread (bps) and Amihud (2002) illiquidity ratio ($\times 10^{-6}$) by pair and regime. Roll spread estimated from daily serial covariance of 1-minute log returns; NaN days (non-negative covariance) excluded from means. ILLIQ$_t = |r_t|/\text  {DollarVol}_t$, daily average.}}{6}{table.2}\protected@file@percent }
\newlabel{tab:liquidity_spread}{{2}{6}{Roll (1984) effective spread (bps) and Amihud (2002) illiquidity ratio ($\times 10^{-6}$) by pair and regime. Roll spread estimated from daily serial covariance of 1-minute log returns; NaN days (non-negative covariance) excluded from means. ILLIQ$_t = |r_t|/\text {DollarVol}_t$, daily average}{table.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Panel A: Roll (1984) effective spread by pair and regime (bps). Panel B: Amihud (2002) ILLIQ ratio ($\times 10^{-6}$). Kraken BTC/USDC shows a $23\times $ Roll spread increase during the crisis; Roll is undefined for Kraken BTC/USD in stress periods (positive serial covariance, momentum regime).}}{6}{figure.5}\protected@file@percent }
\newlabel{fig:liq}{{5}{6}{Panel A: Roll (1984) effective spread by pair and regime (bps). Panel B: Amihud (2002) ILLIQ ratio ($\times 10^{-6}$). Kraken BTC/USDC shows a $23\times $ Roll spread increase during the crisis; Roll is undefined for Kraken BTC/USD in stress periods (positive serial covariance, momentum regime)}{figure.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces HAC Regressions of Adjusted Residual $B_t$ on Crisis Dummy, Realized Volatility, and Range Proxy (Kraken, Newey--West 60 lags)}}{6}{table.3}\protected@file@percent }
\newlabel{tab:regression_hac}{{3}{6}{HAC Regressions of Adjusted Residual $B_t$ on Crisis Dummy, Realized Volatility, and Range Proxy (Kraken, Newey--West 60 lags)}{table.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Daily volume shares across exchange--pair combinations. Trading shifted toward USD and USDT pairs and away from USDC during the SVB crisis window.}}{7}{figure.6}\protected@file@percent }
\newlabel{fig:vol_share}{{6}{7}{Daily volume shares across exchange--pair combinations. Trading shifted toward USD and USDT pairs and away from USDC during the SVB crisis window}{figure.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Hourly realized volatility across BTC pairs. Kraken BTC/USDC spikes to ${\approx }650$ bps/hr during the SVB crisis while USD- and USDT-quoted pairs co-move at ${\approx }150$ bps/hr, demonstrating that the volatility amplification is stablecoin-specific rather than venue-specific.}}{7}{figure.7}\protected@file@percent }
\newlabel{fig:rvol}{{7}{7}{Hourly realized volatility across BTC pairs. Kraken BTC/USDC spikes to ${\approx }650$ bps/hr during the SVB crisis while USD- and USDT-quoted pairs co-move at ${\approx }150$ bps/hr, demonstrating that the volatility amplification is stablecoin-specific rather than venue-specific}{figure.7}{}}
