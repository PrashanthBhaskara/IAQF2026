\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Distribution of the adjusted residual $B_t$ by regime. USDC (Kraken) develops heavy tails beyond $\pm 100$ bps during the crisis; USDT channels widen modestly. Pre-SVB distributions are tightly concentrated near zero.}}{8}{figure.8}\protected@file@percent }
\newlabel{fig:bdist}{{8}{8}{Distribution of the adjusted residual $B_t$ by regime. USDC (Kraken) develops heavy tails beyond $\pm 100$ bps during the crisis; USDT channels widen modestly. Pre-SVB distributions are tightly concentrated near zero}{figure.8}{}}
